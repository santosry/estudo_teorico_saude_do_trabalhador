# Dados brutos CAT/INSS (~1,8 GB) — obter conforme banco de dados/cat-inss/README.md
banco de dados/cat-inss/*.csv

# Material teórico protegido por direitos autorais — não redistribuir
artigos-fonte/*.pdf

# Dados brutos de grande volume — obter conforme documentação de cada fonte
banco de dados/rais/*.7z
banco de dados/sim/*.dbc
banco de dados/sim/*.dbf
banco de dados/sinan/*.dbc
banco de dados/beneficios-inss/*.csv
banco de dados/beneficios-mantidos-inss/_raw_*
banco de dados/anp/*.xlsx
banco de dados/sih/*.dbc
banco de dados/caged/*.7z
banco de dados/caged/*.zip
nul

# Processados grandes (>50MB) - regenerar com scripts do pipeline
dados/processados/sih_campos_2018_2025.csv
dados/processados/sim_campos_obitos_trabalho_2018_2025.csv
dados/processados/sinan_campos_2018_2025.csv
dados/processados/caged_campos_2018_2019.csv

# Artefatos locais
__pycache__/
*.pyc
.ipynb_checkpoints/
Thumbs.db
.DS_Store
~$*.docx
*.tmp
distribuicao/
.pytest_cache/
*.part
